# Railway app service variables for Communication First CRM

GS_STORAGE_BACKEND=local
GS_UPLOADS_PREFIX=communication-first-crm
GS_API_KEY=replace-this
OPENAI_API_KEY=your_openai_api_key_here

# Railway Postgres usually provides DATABASE_URL automatically.
# GS_DATABASE_URL=postgresql+psycopg2://...

GS_CORS_ORIGINS=https://your-generated-domain.up.railway.app
