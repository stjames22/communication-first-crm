# Optional when hosted on Railway: Railway Postgres provides DATABASE_URL automatically.
GS_DATABASE_URL=sqlite:///./barkboys_estimator.db
GS_STORAGE_BACKEND=local
GS_UPLOADS_PATH=./uploads
GS_UPLOADS_PREFIX=barkboys
GS_API_KEY=change-me-before-hosting
GS_CORS_ORIGINS=http://localhost:8000
GS_ESTIMATOR_USER=demo
GS_ESTIMATOR_PASSWORD=demo123
OPENAI_API_KEY=your_openai_api_key_here
GS_OPENAI_VISION_MODEL=gpt-4.1
# Permanent TLS fix for inspected networks: point this at a trusted PEM root certificate bundle.
# GS_OPENAI_CA_BUNDLE=/full/path/to/trusted-root.pem
# Local demo-only fallback for networks that break TLS inspection. Leave off unless you trust the network.
# GS_OPENAI_ALLOW_INSECURE_SSL=1
GS_ALLOW_FALLBACK_HANDWRITTEN_MEASUREMENT_OCR=1

# S3-compatible storage example:
# GS_STORAGE_BACKEND=s3
# GS_S3_BUCKET=your-bucket
# GS_S3_REGION=us-west-2
# GS_S3_ENDPOINT_URL=https://s3.amazonaws.com
# GS_S3_ACCESS_KEY_ID=your-access-key
# GS_S3_SECRET_ACCESS_KEY=your-secret-key
# GS_S3_FORCE_PATH_STYLE=0
