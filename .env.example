GS_DATABASE_URL=sqlite:///./communication_first_crm.db
GS_STORAGE_BACKEND=local
GS_UPLOADS_PATH=./uploads
GS_UPLOADS_PREFIX=communication-first-crm
GS_API_KEY=change-me-before-hosting
GS_CORS_ORIGINS=http://localhost:4174

# Optional OpenAI settings for future communication-assist features.
OPENAI_API_KEY=your_openai_api_key_here
GS_OPENAI_VISION_MODEL=gpt-4.1

# Communication Hub SMS settings.
COMMUNICATION_DEMO_MODE=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VALIDATE_SIGNATURES=true
