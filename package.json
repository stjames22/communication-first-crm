{
  "name": "communication-first-crm",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone communication-first CRM workspace with Postgres, REST APIs, shared inbox, calls, quotes, tasks, and unified activity timeline.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:run": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:setup": "node scripts/setupDb.js",
    "db:seed": "curl -fsS -X POST http://127.0.0.1:3000/api/dev/seed-demo",
    "samples:api": "tsx scripts/sample-api-requests.ts",
    "test:workflow": "tsx scripts/workflow-smoke-test.ts",
    "test:domain": "tsx scripts/domain-regression-test.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
